{
  "$schema": "https://charm.land/crush.json",
  "models": {
    "large": {
      "model": "claude-opus-4.6",
      "provider": "copilot"
    },
    "small": {
      "model": "claude-sonnet-4.5",
      "provider": "copilot"
    }
  },
  "providers": {
    "kimi": {
      "name": "Kimi (Moonshot AI)",
      "type": "openai-compat",
      "base_url": "https://api.moonshot.cn/v1/",
      "api_key": "$KIMI_API_KEY",
      "models": [
        {
          "id": "kimi-k2.5",
          "name": "Kimi K2.5",
          "context_window": 256000,
          "default_max_tokens": 16384
        },
        {
          "id": "kimi-k2-turbo-preview",
          "name": "Kimi K2 Turbo",
          "context_window": 256000,
          "default_max_tokens": 16384
        }
      ]
    },
    "deepseek": {
      "name": "DeepSeek",
      "type": "openai-compat",
      "base_url": "https://api.deepseek.com/v1",
      "api_key": "$DEEPSEEK_API_KEY",
      "models": [
        {
          "id": "deepseek-chat",
          "name": "DeepSeek V3",
          "context_window": 64000,
          "default_max_tokens": 8192
        },
        {
          "id": "deepseek-reasoner",
          "name": "DeepSeek R1",
          "context_window": 64000,
          "default_max_tokens": 8192
        }
      ]
    },
    "ollama": {
      "name": "Ollama (Local)",
      "type": "openai-compat",
      "base_url": "http://localhost:11434/v1/",
      "models": [
        {
          "id": "deepseek-coder-v2:16b",
          "name": "DeepSeek Coder V2 16B",
          "context_window": 128000,
          "default_max_tokens": 16384
        },
        {
          "id": "llama3.1:8b",
          "name": "Llama 3.1 8B",
          "context_window": 128000,
          "default_max_tokens": 8192
        },
        {
          "id": "deepseek-coder:6.7b-instruct-q4_K_M",
          "name": "DeepSeek Coder 6.7B",
          "context_window": 16384,
          "default_max_tokens": 4096
        }
      ]
    }
  },
  "mcp": {
    "fetch": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "mcp-server-fetch"]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "postgres-local": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "${LOCAL_POSTGRES_URL}"
      }
    },
    "postgres-gas-readonly": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${PROD_GAS_URL}"
      }
    },
    "postgres-skjalftalisa-readonly": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${PROD_SKJALFTALISA_URL}"
      }
    },
    "postgres-tos-readonly": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${PROD_TOS_URL}"
      }
    },
    "postgres-epos-readonly": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${DEV_EPOS_URL}"
      }
    },
    "postgres-gnss-readonly": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${DEV_GNSS_URL}"
      }
    },
    "postgres-metrics-readonly": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${DEV_METRICS_URL}"
      }
    }
  },
  "lsp": {
    "python": {
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "filetypes": ["py"],
      "root_markers": ["pyproject.toml", "setup.py", "setup.cfg"]
    },
    "lua": {
      "command": "lua-language-server",
      "args": [],
      "filetypes": ["lua"],
      "root_markers": [".luarc.json", ".luacheckrc"]
    }
  },
  "options": {
    "auto_lsp": true,
    "disable_metrics": true,
    "context_paths": ["CLAUDE.md"],
    "tui": {
      "transparent": true
    }
  }
}
