#!/usr/bin/env python3
"""herdr-cpu-view — live per-core CPU dashboard (runs inside a floating term).

Shows: CPU model, per-core usage bars, and the top process currently running
on each core (via `ps psr`), plus load/mem. Refreshes ~1s. q / Ctrl-C to quit.
"""
import os, sys, time, subprocess, select, termios, tty

def fg(h):
    r=int(h[0:2],16); g=int(h[2:4],16); b=int(h[4:6],16)
    return f"\x1b[38;2;{r};{g};{b}m"
RST="\x1b[0m"; BOLD="\x1b[1m"; HOME="\x1b[H\x1b[J"; HIDE="\x1b[?25l"; SHOW="\x1b[?25h"
GRN=fg("a6e3a1"); YEL=fg("f9e2af"); RED=fg("f38ba8"); BLU=fg("89b4fa")
TEAL=fg("94e2d5"); PCH=fg("fab387"); LAV=fg("b4befe"); SUB=fg("6c7086"); TXT=fg("cdd6f4")
BLOCKS=" ▏▎▍▌▋▊▉█"

def cpu_model():
    try:
        for l in open('/proc/cpuinfo'):
            if l.startswith('model name'): return l.split(':',1)[1].strip()
    except Exception: pass
    return "CPU"

def read_stat():
    cores={}
    for l in open('/proc/stat'):
        if l.startswith('cpu') and len(l)>3 and l[3].isdigit():
            p=l.split(); n=int(p[0][3:]); v=list(map(int,p[1:9]))
            cores[n]=(sum(v), v[3]+v[4])   # (total, idle)
    return cores

def bar(pct,width=18):
    filled=pct/100.0*width; full=int(filled)
    frac=BLOCKS[int((filled-full)*8)] if full<width else ""
    col=RED if pct>=80 else (YEL if pct>=50 else GRN)
    pad=width-full-(1 if frac else 0)
    return col+("█"*full)+frac+SUB+("░"*max(0,pad))+RST

def top_proc_per_core():
    out={}
    try:
        r=subprocess.run(['ps','-eo','psr,pcpu,rss,comm','--no-headers'],
                         capture_output=True,text=True,timeout=2)
        for line in r.stdout.splitlines():
            f=line.split(None,3)
            if len(f)<4: continue
            try: psr=int(f[0]); pc=float(f[1]); rss=int(f[2])
            except ValueError: continue
            if pc<=0: continue
            if psr not in out or pc>out[psr][1]: out[psr]=(f[3],pc,rss)
    except Exception: pass
    return out

def sysline():
    try: ld=open('/proc/loadavg').read().split()[0]
    except Exception: ld='?'
    nc=os.cpu_count() or 1
    try:
        mm=subprocess.run(['free','-h'],capture_output=True,text=True).stdout
        mem=[x for x in mm.splitlines() if x.startswith('Mem:')][0].split()[2]
    except Exception: mem='?'
    return f"{PCH}{BOLD}load {ld}{RST}{SUB}/{nc}{RST}    {TEAL}{BOLD}mem {mem}{RST}"

def key_pressed():
    dr,_,_=select.select([sys.stdin],[],[],0)
    if dr:
        c=sys.stdin.read(1)
        return c in ('q','Q','\x03')
    return False

def main():
    model=cpu_model(); ncores=os.cpu_count() or 1
    prev=read_stat()
    fd=sys.stdin.fileno(); old=None
    try: old=termios.tcgetattr(fd); tty.setcbreak(fd)
    except Exception: pass
    sys.stdout.write(HIDE)
    try:
        while True:
            # ~1s refresh, but poll keys every 100ms
            for _ in range(10):
                time.sleep(0.1)
                if key_pressed(): return
            cur=read_stat(); procs=top_proc_per_core()
            out=[HOME]
            out.append(f"{BLU}{BOLD}  {model}{RST}   {SUB}({ncores} logical cores){RST}\n")
            out.append(f"{SUB}  core  usage                %     top process              mem{RST}\n")
            out.append(f"{SUB}  ────────────────────────────────────────────────────────────────────{RST}\n")
            for n in sorted(cur):
                t0,i0=prev.get(n,cur[n]); t1,i1=cur[n]
                dt=t1-t0; di=i1-i0
                pct=0 if dt<=0 else max(0,min(100,round(100*(dt-di)/dt)))
                pcol=RED if pct>=80 else (YEL if pct>=50 else TXT)
                ent=procs.get(n)
                if ent:
                    comm,pc,rss=ent
                    mb=rss//1024
                    mem_s=f"{rss/1048576:.1f}G" if mb>=1024 else f"{mb}M"
                    pc_s=(f"{LAV}{comm[:16]:<16}{RST}{SUB} {pc:.0f}%{RST}"
                          f"   {TEAL}{mem_s:>6}{RST}")
                else:
                    pc_s=f"{SUB}idle{RST}"
                out.append(f"  {TEAL}{n:>3}{RST}  {bar(pct)}  {pcol}{pct:>3}%{RST}   {pc_s}\n")
            out.append("\n")
            out.append(f"  {sysline()}    {SUB}⟳ 1s   press q to quit{RST}\n")
            sys.stdout.write("".join(out)); sys.stdout.flush()
            prev=cur
    except KeyboardInterrupt:
        pass
    finally:
        sys.stdout.write(SHOW)
        if old is not None:
            try: termios.tcsetattr(fd,termios.TCSADRAIN,old)
            except Exception: pass

if __name__=="__main__":
    main()
