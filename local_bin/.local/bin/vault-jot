#!/usr/bin/env bash
# vault-jot — Quick capture to Obsidian daily note
# Bound to $mod+Ctrl+j in Sway
#
# Usage:
#   vault-jot                              # rofi popup for input (today)
#   vault-jot Buy milk                     # plain jot to today
#   vault-jot todo Fix thing               # task to today
#   vault-jot todo Fix thing due:2026-03-01  # task with due date
#   vault-jot todo Fix thing @2026-03-01   # task with due date (shorthand)
#   vault-jot todo Fix thing start:2026-03-28 due:2026-04-01  # scheduled + due
#   vault-jot todo Fix thing ~2026-03-28   # scheduled date (shorthand)
#   vault-jot tm Call dentist              # jot to tomorrow
#   vault-jot yd Forgot to log             # jot to yesterday
#   vault-jot nw Plan sprint               # jot to next monday
#   vault-jot lw Should have noted this    # jot to last monday
#   vault-jot 2026-03-01 Some note         # jot to specific date
#   vault-jot --help                       # show usage

set -euo pipefail

VAULT_DIR="${HOME}/notes/bgovault"
DAILY_DIR="${VAULT_DIR}/Journal/daily"

# ── Help ──────────────────────────────────────────────────────────────
show_help() {
    cat <<'EOF'
vault-jot — Quick capture to Obsidian daily note

USAGE:
  vault-jot [DATE] [todo] <text> [due:YYYY-MM-DD | @YYYY-MM-DD]
  vault-jot                        # rofi popup (today)
  vault-jot --help                 # this message

DATE ALIASES (optional first argument):
  t          today (default)
  tm         tomorrow
  yd         yesterday
  nw         next monday
  lw         last monday
  tomorrow   tomorrow (long form)
  yesterday  yesterday (long form)
  YYYY-MM-DD specific date

TASK MODE:
  Start text with "todo" to create a checkbox task.
  Append due:YYYY-MM-DD or @YYYY-MM-DD for a due date (📅 deadline).
  Append start:YYYY-MM-DD or ~YYYY-MM-DD for a scheduled date (⏳ start working).

EXAMPLES:
  vault-jot Buy milk
  vault-jot tm Call dentist
  vault-jot todo Fix timeout due:2026-03-01
  vault-jot tm todo Review PR @2026-03-02
  vault-jot todo Plan proposal start:2026-03-28 due:2026-04-01
  vault-jot todo Prep slides ~2026-03-28
  vault-jot nw Plan sprint goals
  vault-jot yd Forgot to log meeting
EOF
    exit 0
}

# ── Create a daily note if it doesn't exist ───────────────────────────
# Delegates to vault-create-daily (single source of truth for template)
ensure_daily_note() {
    "${HOME}/.local/bin/vault-create-daily" "$1"
}

# ── Parse date target ─────────────────────────────────────────────────
resolve_date() {
    case "${1:-}" in
        --help|-h)
            show_help
            ;;
        t)
            TARGET_DATE=$(date +%Y-%m-%d)
            return 0
            ;;
        tm|tomorrow)
            TARGET_DATE=$(date -d "tomorrow" +%Y-%m-%d)
            return 0
            ;;
        yd|yesterday)
            TARGET_DATE=$(date -d "yesterday" +%Y-%m-%d)
            return 0
            ;;
        nw)
            # Next monday
            TARGET_DATE=$(date -d "next monday" +%Y-%m-%d)
            return 0
            ;;
        lw)
            # Last monday
            TARGET_DATE=$(date -d "last monday" +%Y-%m-%d)
            return 0
            ;;
        [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9])
            # Validate the date
            if date -d "$1" +%Y-%m-%d &>/dev/null; then
                TARGET_DATE="$1"
                return 0
            fi
            # Invalid date — treat as content
            return 1
            ;;
        *)
            return 1
            ;;
    esac
}

# Default: today
TARGET_DATE=$(date +%Y-%m-%d)
NOW_TIME=$(date +%H:%M)
TODAY=$(date +%Y-%m-%d)

# Try to parse first arg as date target
if [[ $# -gt 0 ]] && resolve_date "$1"; then
    shift
fi

DAILY_FILE="${DAILY_DIR}/${TARGET_DATE}.md"

# ── Get input ─────────────────────────────────────────────────────────
if [[ $# -gt 0 ]]; then
    # Check for --help anywhere in args
    for arg in "$@"; do
        [[ "$arg" == "--help" || "$arg" == "-h" ]] && show_help
    done
    INPUT="$*"
else
    INPUT=$(rofi -dmenu -p "Jot" -theme-str 'window { width: 600px; }' -lines 0 2>/dev/null) || exit 0
fi

# Exit if empty
[[ -z "${INPUT}" ]] && exit 0

# ── Parse date alias from input (handles rofi and CLI the same way) ──
# If the first word is a date alias, consume it and re-target the date.
FIRST_WORD="${INPUT%% *}"
if resolve_date "${FIRST_WORD}"; then
    # Strip the date alias from input (handle single-word case)
    if [[ "${INPUT}" == *" "* ]]; then
        INPUT="${INPUT#* }"
    else
        INPUT=""
    fi
    DAILY_FILE="${DAILY_DIR}/${TARGET_DATE}.md"
fi

# Exit if input was only a date alias with no text
[[ -z "${INPUT}" ]] && exit 0

# ── Create daily note if needed ───────────────────────────────────────
ensure_daily_note "${TARGET_DATE}"

# ── Format the entry ──────────────────────────────────────────────────
if [[ "${INPUT,,}" == todo\ * ]]; then
    # Task mode: strip "todo " prefix
    TASK_TEXT="${INPUT:5}"

    # Extract scheduled date: start:YYYY-MM-DD, start: YYYY-MM-DD, or ~YYYY-MM-DD
    SCHEDULED_DATE=""
    if [[ "${TASK_TEXT}" =~ (start:[[:space:]]?|~)([0-9]{4}-[0-9]{2}-[0-9]{2}) ]]; then
        SCHEDULED_DATE="${BASH_REMATCH[2]}"
        TASK_TEXT=$(echo "${TASK_TEXT}" | sed -E 's/(start:[[:space:]]?|~)[0-9]{4}-[0-9]{2}-[0-9]{2}//g' | sed 's/[[:space:]]*$//' | sed 's/[[:space:]]\+/ /g')
    fi

    # Extract due date: due:YYYY-MM-DD, due: YYYY-MM-DD, or @YYYY-MM-DD
    DUE_DATE=""
    if [[ "${TASK_TEXT}" =~ (due:[[:space:]]?|@)([0-9]{4}-[0-9]{2}-[0-9]{2}) ]]; then
        DUE_DATE="${BASH_REMATCH[2]}"
        TASK_TEXT=$(echo "${TASK_TEXT}" | sed -E 's/(due:[[:space:]]?|@)[0-9]{4}-[0-9]{2}-[0-9]{2}//g' | sed 's/[[:space:]]*$//' | sed 's/[[:space:]]\+/ /g')
    fi

    ENTRY="- [ ] ${TASK_TEXT} ➕ ${TODAY}"
    if [[ -n "${SCHEDULED_DATE}" ]]; then
        ENTRY="${ENTRY} ⏳ ${SCHEDULED_DATE}"
    fi
    if [[ -n "${DUE_DATE}" ]]; then
        ENTRY="${ENTRY} 📅 ${DUE_DATE}"
    fi
    NOTIFY_MSG="Task → ${TARGET_DATE}: ${TASK_TEXT}"
else
    # Plain jot mode
    ENTRY="- ${INPUT} (${NOW_TIME})"
    NOTIFY_MSG="Jot → ${TARGET_DATE}: ${INPUT}"
fi

# ── Append entry to the appropriate section ──────────────────────────
# Tasks (- [ ] ...) go under ## Verkefni dagsins; plain jots under ## Skyndiminnispunktar
insert_under_section() {
    local section_heading="$1"
    local entry="$2"
    local file="$3"

    local section_line
    section_line=$(grep -n "^## ${section_heading}$" "${file}" | head -1 | cut -d: -f1)

    if [[ -z "${section_line}" ]]; then
        # Section not found — append to end of file
        printf '\n## %s\n\n%s\n' "${section_heading}" "${entry}" >> "${file}"
        return
    fi

    # For Verkefni dagsins: insert before the first ### subsection
    # For Skyndiminnispunktar: insert before the next ## heading
    local pattern
    if [[ "${section_heading}" == "Verkefni dagsins" ]]; then
        pattern="^### "
    else
        pattern="^## "
    fi

    local next_heading
    next_heading=$(tail -n +"$((section_line + 1))" "${file}" | grep -n "${pattern}" | head -1 | cut -d: -f1)

    if [[ -n "${next_heading}" ]]; then
        local next_heading_abs=$((section_line + next_heading))
        # Walk back over blank lines to find last content line
        local insert_line=$((next_heading_abs - 1))
        while [[ $insert_line -gt $section_line ]] && \
              [[ -z "$(sed -n "${insert_line}p" "${file}" | tr -d '[:space:]')" ]]; do
            insert_line=$((insert_line - 1))
        done
        sed -i "$((insert_line + 1))i\\${entry}" "${file}"
    else
        # No next heading — append to end of file
        printf '%s\n' "${entry}" >> "${file}"
    fi
}

if [[ "${ENTRY}" == "- [ ] "* ]]; then
    insert_under_section "Verkefni dagsins" "${ENTRY}" "${DAILY_FILE}"
else
    insert_under_section "Skyndiminnispunktar" "${ENTRY}" "${DAILY_FILE}"
fi

# ── Output confirmation ──────────────────────────────────────────────
echo "${NOTIFY_MSG}"

# Desktop notification (best-effort)
notify-send -t 3000 "Vault Jot" "${NOTIFY_MSG}" -i dialog-information 2>/dev/null || true
