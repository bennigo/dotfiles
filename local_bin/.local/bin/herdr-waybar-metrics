#!/bin/bash
# herdr-waybar-metrics â€” per-section waybar modules for the thin top bar.
# Arg selects the section (each is its own clickable waybar module):
#   network  battery  vpn  localip  pubip  sysmon  cpu   (default: all = legacy)
set -eu
b=#89b4fa; g=#a6e3a1; y=#f9e2af; r=#f38ba8; t=#94e2d5; p=#fab387
o=#939ab7; s=#6c7086; tx=#cdd6f4; dim="#6c7086cc"
sp(){ printf '<span color="%s">%s</span>' "$1" "$2"; }
sb(){ printf '<span color="%s" font_weight="bold">%s</span>' "$1" "$2"; }
se(){ printf '<span color="%s">  â”‚  </span>' "$s"; }
emit(){ python3 -c "import json,sys;print(json.dumps({'text':sys.argv[1],'class':sys.argv[2],'tooltip':sys.argv[3]}))" "$1" "$2" "${3:-}"; }

wifi_dev(){ nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null|grep ':wifi:connected'|head -1|cut -d: -f1; }

section="${1:-all}"

net_section(){
    local wd; wd=$(wifi_dev)
    if [ -n "$wd" ]; then
        local wi ssid sig sc
        wi=$(nmcli -t -f ACTIVE,SSID,SIGNAL dev wifi 2>/dev/null|grep '^yes'|head -1)
        ssid=$(echo "$wi"|cut -d: -f2); sig=$(echo "$wi"|cut -d: -f3)
        [ -n "$sig" ]&&{ [ "$sig" -ge 60 ] 2>/dev/null&&sc="$g"||{ [ "$sig" -ge 30 ] 2>/dev/null&&sc="$y"||sc="$r";};}||sc="$g"
        printf '%s %s %s' "$(sp "$g" "ًں“¶")" "$(sb "$sc" "${ssid:-wifi}")" "$(sb "$sc" "${sig:-?}%")"
    else
        local eth; eth=$(nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null|grep ':ethernet:connected'|head -1|cut -d: -f1)
        [ -n "$eth" ]&&printf '%s' "$(sp "$g" "ًں”— eth")"||printf '%s' "$(sp "$r" "â‌Œ offline")"
    fi
}

case "$section" in
network)
    emit "$(net_section)" "metric-network" "Click: network menu"
    ;;
localip)
    lip=$(ip -o -4 addr show dev "$(wifi_dev)" 2>/dev/null|awk '{print $4}'|cut -d/ -f1|head -1)
    [ -z "$lip" ]&&lip="â€”"
    emit "$(sp "$o" "ًںŒگ") $(sb "$t" "$lip")" "metric-ip" "Click: copy local IP ($lip)"
    ;;
pubip)
    PUB="$XDG_RUNTIME_DIR/herdr-pubip"; pub=""
    [ -f "$PUB" ]&&{ read -r ts pub2 < "$PUB"; [ $(($(date +%s)-ts)) -lt 300 ]&&pub="$pub2";}
    [ -z "$pub" ]&&{ pub=$(dig +short myip.opendns.com @resolver1.opendns.com 2>/dev/null|head -1); [ -n "$pub" ]&&printf '%s %s\n' "$(date +%s)" "$pub" > "$PUB";}
    [ -z "$pub" ]&&pub="â€¦"
    emit "$(sp "$o" "ًںŒچ") $(sb "$t" "$pub")" "metric-ip" "Click: copy public IP ($pub)"
    ;;
vpn)
    vif=$(ip -o link show up 2>/dev/null|awk -F': ' '{print $2}'|cut -d'@' -f1|grep -iE '^(tun|tap|wg|cscotun)'|head -1)
    if [ -n "$vif" ]; then
        vip=$(ip -o -4 addr show dev "$vif" 2>/dev/null|awk '{print $4}'|cut -d/ -f1|head -1)
        emit "$(sp "$g" "ًں”’") $(sp "$dim" "${vip:---}")" "metric-vpn" "VPN up ($vif) â€” click: VPN menu"
    else
        emit "$(sp "$dim" "ًں”“ â€”")" "metric-vpn" "No VPN â€” click: VPN menu"
    fi
    ;;
sysmon)
    ld=$(cut -d' ' -f1 /proc/loadavg 2>/dev/null); nc=$(nproc 2>/dev/null)
    mm=$(free -h 2>/dev/null|awk '/^Mem:/{print $3}')
    emit "$(sb "$p" "load ${ld}")$(sp "$dim" "/${nc}")$(se)$(sb "$t" "mem ${mm}")" "metric-sys" "Click: htop"
    ;;
cpu)
    read -r u ns si id io irq siq st <<< "$(awk '/^cpu /{print $2,$3,$4,$5,$6,$7,$8,$9;exit}' /proc/stat 2>/dev/null)"
    ct=$(( ${u:-0}+${ns:-0}+${si:-0}+${id:-0}+${io:-0}+${irq:-0}+${siq:-0}+${st:-0} ))
    CF="$XDG_RUNTIME_DIR/herdr-cpu-prev"; cpu_s=""
    [ -f "$CF" ]&&{ read -r pt pi2 < "$CF"; [ "$ct" -gt "$pt" ]&&{
        dt=$((ct-pt)); di=$(( (${id:-0}+${io:-0}) - pi2 )); pc=$((100*(dt-di)/dt))
        fl=$((pc/10)); [ "$fl" -gt 8 ]&&fl=8; [ "$fl" -lt 0 ]&&fl=0
        em=$((8-fl)); bar=""; i=0
        while [ $i -lt $fl ]; do bar="${bar}â– "; i=$((i+1)); done
        i=0; while [ $i -lt $em ]; do bar="${bar}â–،"; i=$((i+1)); done
        [ "$pc" -ge 80 ]&&cc="$r"||{ [ "$pc" -ge 50 ]&&cc="$y"||cc="$g";}
        cpu_s="$(sp "$p" "cpu ")$(sb "$cc" "$bar") $(sb "$tx" "${pc}%")"
    };}
    [ -z "$cpu_s" ]&&cpu_s="$(sp "$p" "cpu ")$(sp "$dim" "â€¦")"
    printf '%s %s\n' "$ct" "$((${id:-0}+${io:-0}))" > "$CF"
    emit "$cpu_s" "metric-cpu" "Click: per-core CPU detail"
    ;;
battery)
    bat_s=""; [ -d /sys/class/power_supply/BAT0 ]&&{ pct=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
        stat=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)
        ico="ًں”‹"; [ "$stat" = "Charging" ]&&ico="ًں”Œ"
        [ -n "$pct" ]&&{ [ "$pct" -ge 50 ] 2>/dev/null&&bc="$g"||{ [ "$pct" -ge 20 ] 2>/dev/null&&bc="$y"||bc="$r";}
        bat_s="$(sb "$bc" "${ico} ${pct}%")";};}
    [ -z "$bat_s" ]&&bat_s="$(sp "$dim" "ًں”‹ â€”")"
    emit "$bat_s" "metric-battery" "Click: power menu"
    ;;
bluetooth)
    bt=""; names=""
    if command -v bluetoothctl >/dev/null 2>&1; then
        while read -r _ mac rest; do
            [ -z "$mac" ]&&continue
            ico=$(bluetoothctl info "$mac" 2>/dev/null|sed 's/\x1b\[[0-9;]*m//g'|awk -F': ' '/Icon:/{print $2;exit}')
            case "$ico" in
                audio-headset|audio-headphones) gi="َ°‹‹" ;;
                audio-card|audio-speakers)      gi="َ°“ƒ" ;;
                earbuds)                        gi="َ±ڑ‡" ;;
                input-keyboard)                 gi="َ°ŒŒ" ;;
                input-mouse|input-tablet)       gi="َ°چ½" ;;
                input-gaming)                   gi="َ°®“" ;;
                phone)                          gi="َ°ڈ²" ;;
                watch|wearable)                 gi="َ°¥”" ;;
                *)                              gi="َ°‚±" ;;
            esac
            bt="${bt}${bt:+ }$(sp "$b" "$gi")"
            names="${names}${names:+, }${rest}"
        done < <(bluetoothctl devices Connected 2>/dev/null|sed 's/\x1b\[[0-9;]*m//g')
    fi
    if [ -n "$bt" ]; then
        emit "$(sp "$b" "َ°‚±") $bt" "metric-bt" "Connected: $names â€” click: bluetooth manager"
    else
        pw=$(bluetoothctl show 2>/dev/null|sed 's/\x1b\[[0-9;]*m//g'|awk -F': ' '/Powered:/{print $2;exit}')
        if [ "$pw" = "yes" ]; then
            emit "$(sp "$dim" "َ°‚¯")" "metric-bt" "Bluetooth on, no devices â€” click: manager"
        else
            emit "$(sp "$dim" "َ°‚²")" "metric-bt" "Bluetooth off â€” click: manager"
        fi
    fi
    ;;
esac
