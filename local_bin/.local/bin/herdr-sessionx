#!/bin/bash
## Herdr // sessionx-style workspace picker (fzf + zoxide) // 🦉 ##
#
# Bound to prefix+o in herdr config.
#
# Default view: EXISTING workspaces only (clean). Press:
#   ctrl-r  reveal recent dirs (zoxide) — open as new workspace
#   ctrl-w  back to workspaces-only view
#   ctrl-p  toggle preview pane on/off (off by default)
#   ENTER   open  ·  ESC cancel
#
# Lines are "type<TAB>target<TAB>display"; fzf shows only the display column.

set -euo pipefail

ALL=0
[ "${1:-}" = "--all" ] && ALL=1

# --- source builder ---------------------------------------------------------
build_source() {
    # Existing workspaces — always shown. Clean line: focused-marker, wsN, label, agent state.
    herdr workspace list 2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    for w in d['result']['workspaces']:
        mark = '*' if w['focused'] else ' '
        agent = w.get('agent_status','') or ''
        agent_str = f'  <{agent}>' if agent else ''
        print(f'ws\t{w[\"workspace_id\"]}\t{mark} ws{w[\"number\"]}: {w[\"label\"]}{agent_str}')
except Exception:
    pass
"
    # Zoxide recent dirs — only in --all mode
    if [ "$ALL" = 1 ]; then
        zoxide query -l 2>/dev/null | while IFS= read -r dir; do
            [ -d "$dir" ] && printf 'zo\t%s\t  %s\n' "$dir" "$dir"
        done
    fi
}

# --- header -----------------------------------------------------------------
if [ "$ALL" = 1 ]; then
    header="workspaces + recent dirs  ·  ctrl-w workspaces only  ·  ctrl-p preview  ·  ENTER open · ESC cancel"
else
    header="workspaces  ·  ctrl-r recent dirs  ·  ctrl-p preview  ·  ENTER open · ESC cancel"
fi

# --- preview (only relevant when toggled on) --------------------------------
preview_cmd='line={}; t=$(printf "%s" "$line" | cut -f1); p=$(printf "%s" "$line" | cut -f2); if [ "$t" = zo ]; then ls -la --color=always "$p" 2>/dev/null | head -40; else herdr workspace get "$p" 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); w=d[\"result\"][\"workspace\"]; print(f\"workspace {w[\"workspace_id\"]}: {w[\"label\"]}\\nagent: {w.get(\"agent_status\",\"-\")}\\ntabs: {w[\"tab_count\"]}  panes: {w[\"pane_count\"]}\")" 2>/dev/null; fi'

# --- run picker -------------------------------------------------------------
pick=$( build_source | fzf --ansi \
       --delimiter='\t' \
       --with-nth=3 \
       --no-sort \
       --header="$header" \
       --preview="$preview_cmd" \
       --preview-window='hidden:right:50%:wrap' \
       --bind 'ctrl-r:reload(~/.local/bin/herdr-sessionx --all)' \
       --bind 'ctrl-w:reload(~/.local/bin/herdr-sessionx)' \
       --bind 'ctrl-p:toggle-preview' \
       --prompt='workspace> ' || true )

# ESC or empty selection
[ -z "${pick:-}" ] && exit 0

type=$(printf '%s' "$pick" | cut -f1)
target=$(printf '%s' "$pick" | cut -f2)

case "$type" in
    ws)  herdr workspace focus "$target" ;;
    zo)  herdr workspace create --cwd "$target" --focus ;;
esac
