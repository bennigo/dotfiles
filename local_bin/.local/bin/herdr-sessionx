#!/bin/bash
## Herdr // sessionx-style workspace picker (fzf + zoxide) // 🦉 ##
#
# Bound to prefix+o in herdr config. Self-contained: four modes (see case below).
#
# Display is label-centric (project name + full cwd path disambiguates same-named
# projects; agent state shown only when known; tabs/panes counts).
# Type any path + Enter to open it as a new workspace even if not in zoxide.
#
# Picker keys:  ctrl-r recent dirs · ctrl-w workspaces only · ctrl-p preview · ENTER open

set -euo pipefail

ALL=0; SOURCE_ONLY=0; PREVIEW=0
while [ $# -gt 0 ]; do
    case "$1" in
        --all)     ALL=1; shift ;;
        --source)  SOURCE_ONLY=1; shift ;;
        --preview) PREVIEW=1; shift; break ;;
        *) shift ;;
    esac
done

# ── helper: resolve a workspace's cwd via its first pane ────────────────────
ws_cwd() {
    herdr pane list --workspace "$1" 2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)['result']
    ps = d.get('panes') or d.get('pane_list') or []
    print(ps[0]['pane_id'] if ps else '')
except Exception:
    pass
" 2>/dev/null | while IFS= read -r pane; do
        [ -n "$pane" ] || continue
        herdr pane get "$pane" 2>/dev/null | python3 -c "
import json, sys
try: print(json.load(sys.stdin)['result']['pane']['cwd'])
except Exception: pass
" 2>/dev/null
        break
    done
}

# ── helper: print git status + commits + recent files for a dir ─────────────
dir_preview() {
    local dir="$1"
    [ -d "$dir" ] || return 0
    if git -C "$dir" rev-parse --git-dir >/dev/null 2>&1; then
        local st
        st=$(git -C "$dir" -c safe.directory='*' status -sb --color=always 2>/dev/null | head -8)
        [ -n "$st" ] && { echo '▼ git status'; echo "$st"; echo; }
        local log
        log=$(git -C "$dir" -c safe.directory='*' log --oneline --color=always -12 2>/dev/null)
        [ -n "$log" ] && { echo '▼ recent commits'; echo "$log"; echo; }
    fi
    local files
    files=$(find "$dir" -maxdepth 2 -type f -mtime -14 \
        -not -path '*/.git/*' -not -path '*/node_modules/*' -not -path '*/__pycache__/*' \
        -printf '%TY-%Tm-%Td %TH:%TM  %p\n' 2>/dev/null | sort -rn | head -15 | sed "s|$dir/||")
    [ -n "$files" ] && { echo '▼ recent files (14d)'; echo "$files"; }
}

# ── preview mode ────────────────────────────────────────────────────────────
if [ "$PREVIEW" = 1 ]; then
    set +e +o pipefail
    ptype="${1:-}"; ptarget="${2:-}"
    case "$ptype" in
        zo)
            [ -d "$ptarget" ] && dir_preview "$ptarget"
            ;;
        ws)
            # Header by LABEL (not raw id) + dir preview resolved from cwd
            herdr workspace get "$ptarget" 2>/dev/null | python3 -c "
import json, sys
try:
    w = json.load(sys.stdin)['result']['workspace']
    print(f\"{w['label']}   <{w.get('agent_status','-')}>   [{w['tab_count']}t/{w['pane_count']}p]\")
except Exception:
    pass
" 2>/dev/null
            echo
            dir="$(ws_cwd "$ptarget")"
            if [ -n "$dir" ] && [ -d "$dir" ]; then
                dir_preview "$dir"
            else
                echo "(no cwd resolved)"
            fi
            ;;
    esac
    exit 0
fi

# ── source builder ──────────────────────────────────────────────────────────
build_source() {
    # Merge workspace list with pane cwds in one pass (single pane-list call)
    python3 -c "
import json, subprocess, os
def run(cmd):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        return json.loads(r.stdout) if r.stdout else {}
    except Exception:
        return {}
wl = run('herdr workspace list').get('result', {}).get('workspaces', [])
panes = run('herdr pane list').get('result', {})
panes = panes.get('panes') or panes.get('pane_list') or []
cwd_by_ws = {}
for p in panes:
    ws = p.get('workspace_id')
    if ws and ws not in cwd_by_ws and p.get('cwd'):
        cwd_by_ws[ws] = p['cwd']
home = os.path.expanduser('~')
for w in wl:
    mark = '*' if w.get('focused') else ' '
    label = w.get('label', '?')
    cwd = cwd_by_ws.get(w['workspace_id'], '')
    cwd_s = ('~' + cwd[len(home):]) if cwd and cwd.startswith(home) else (cwd or '')
    agent = (w.get('agent_status') or '').strip()
    agent_s = f'  <{agent}>' if agent and agent != 'unknown' else ''
    tp = f'  [{w.get(\"tab_count\",0)}t/{w.get(\"pane_count\",0)}p]'
    print(f'ws\t{w[\"workspace_id\"]}\t{mark} {label}  {cwd_s}{agent_s}{tp}')
"
    if [ "$ALL" = 1 ]; then
        zoxide query -l 2>/dev/null | head -30 | while IFS= read -r dir; do
            [ -d "$dir" ] && printf 'zo\t%s\t  %s\n' "$dir" "$dir"
        done
    fi
}

# ── source-only mode (fzf reload) ───────────────────────────────────────────
if [ "$SOURCE_ONLY" = 1 ]; then
    build_source
    exit 0
fi

# ── picker ──────────────────────────────────────────────────────────────────
if [ "$ALL" = 1 ]; then
    header="workspaces + recent dirs  ·  ctrl-w clean  ·  ctrl-p preview  ·  type a path to open it · ENTER · ESC"
else
    header="workspaces  ·  ctrl-r recent dirs  ·  ctrl-p preview  ·  type a path to open it · ENTER · ESC"
fi

# --print-query: line 1 = query, line 2 = selection (empty if user typed a non-matching path)
output=$( build_source | fzf --ansi \
       --delimiter='\t' \
       --with-nth=3 \
       --no-sort \
       --print-query \
       --header="$header" \
       --preview='~/.local/bin/herdr-sessionx --preview {1} {2}' \
       --preview-window='hidden:right:60%:wrap' \
       --bind 'ctrl-r:reload(~/.local/bin/herdr-sessionx --source --all)' \
       --bind 'ctrl-w:reload(~/.local/bin/herdr-sessionx --source)' \
       --bind 'ctrl-p:toggle-preview' \
       --prompt='workspace> ' || true )

query=$(printf '%s\n' "$output" | head -1)
pick=$(printf '%s\n' "$output" | sed -n '2p')

if [ -n "$pick" ]; then
    type=$(printf '%s' "$pick" | cut -f1)
    target=$(printf '%s' "$pick" | cut -f2)
    case "$type" in
        ws)  herdr workspace focus "$target" ;;
        zo)  herdr workspace create --cwd "$target" --focus ;;
    esac
elif [ -n "$query" ]; then
    # Typed a path not in the list → expand ~ and open as new workspace
    case "$query" in
        '~'*) query="$HOME${query#~}" ;;
    esac
    if [ -d "$query" ]; then
        herdr workspace create --cwd "$query" --focus
    else
        echo "not a directory: $query" >&2
        exit 1
    fi
fi
