#!/usr/bin/env bash
# After resume: refresh Wayland env vars in all tmux panes.
# Panes that were open before suspend have stale WAYLAND_DISPLAY/SWAYSOCK.
if pgrep -x tmux &>/dev/null; then
    tmux list-panes -a -F '#{pane_id}' \
        | xargs -I{} tmux send-keys -t {} 'refresh-wayland-env' Enter 2>/dev/null || true
fi
