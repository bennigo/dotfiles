#!/usr/bin/env bash
# Triggered by udev when AC power is disconnected.
# Suspends the system only if the lid is currently closed.
# Runs as root via systemd-run from a udev RUN+ directive.

set -euo pipefail

STAMP="/tmp/lid-ac-suspend.stamp"
NOW=$(date +%s)
if [[ -f "$STAMP" ]]; then
    LAST=$(cat "$STAMP")
    AGE=$(( NOW - LAST ))
    if (( AGE < 60 )); then
        logger -t lid-ac-suspend "AC disconnected but cooldown active (${AGE}s since last trigger) — skipping"
        exit 0
    fi
fi
echo "$NOW" > "$STAMP"

LID_STATE=""
for state_file in /proc/acpi/button/lid/*/state; do
    [[ -f "$state_file" ]] && LID_STATE=$(awk '{print $2}' "$state_file") && break
done

if [[ "$LID_STATE" == "closed" ]]; then
    logger -t lid-ac-suspend "AC disconnected with lid closed — locking and suspending"
    loginctl lock-sessions
    sleep 1
    systemctl suspend
else
    logger -t lid-ac-suspend "AC disconnected, lid is open — no action"
fi
