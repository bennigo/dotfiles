[Unit]
Description=Periodic sync of dotfiles, claude-private, password-store, bgovault
Documentation=man:systemd.timer(5)

[Timer]
# Run sync every 4 hours. NOTE: keep this interval conservative — the full
# sync auto-commits the *entire* dotfiles working tree (git add . + generated
# message), so a short interval commits mid-edit WIP with junk messages.
# The vault (push-only, safe) runs hourly via bgovault-sync.timer instead.
OnBootSec=10min
OnUnitActiveSec=4h

# Run on calendar schedule as well (daily at 9am, 1pm, 5pm, 9pm)
OnCalendar=*-*-* 09,13,17,21:00:00

# Randomize start time by up to 5 minutes to avoid conflicts
RandomizedDelaySec=5min

# Persist timer state across reboots
Persistent=true

[Install]
WantedBy=timers.target
