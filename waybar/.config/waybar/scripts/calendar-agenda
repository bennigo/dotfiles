#!/usr/bin/env bash
# Show upcoming agenda from both Google accounts as a Mako notification
clean() {
    sed 's/\x1b\[[0-9;]*m//g' |  # strip ANSI
    sed '/^$/d' |                  # remove blank lines
    sed 's/No Events Found.*/No events/' |
    sed 's/  \+/ /g' |            # collapse multiple spaces
    head -15
}

END=$(date -d "+90 days" '+%Y-%m-%dT23:59')

P=$(gcalcli agenda --nostarted --nocolor "now" "$END" 2>/dev/null | clean)
K=$(XDG_DATA_HOME="$HOME/.local/share/gcalcli-ki" gcalcli agenda --nostarted --nocolor "now" "$END" 2>/dev/null | clean)

BODY=$(printf "Personal:\n%s\n\nKI:\n%s" "${P:-No events}" "${K:-No events}")
notify-send -a calendar -c calendar -t 15000 "Upcoming" "$BODY"
