{
    "layer": "top",
    "position": "top",
    "exclusive": false,
    "height": 64,
    "margin-top": 42,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [],
    "modules-center": ["custom/herdr"],
    "modules-right": [],
    "custom/herdr": {
        "exec": "~/.local/bin/herdr-waybar-status",
        "return-type": "json",
        "interval": 3,
        "exec-on-event": false,
        "tooltip": false,
        "format": "{}"
    }
}
