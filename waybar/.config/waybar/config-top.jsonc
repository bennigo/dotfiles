{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
        "custom/metrics",
        "custom/bluetooth",
        "clock",
        "sway/language",
        "idle_inhibitor",
        "custom/dnd",
        "custom/power"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true
    },
    "sway/language": {
        "format": "󰌌 {}",
        "min-length": 3,
        "tooltip": false,
        "on-click": "swaymsg input $(swaymsg -t get_inputs --raw | jq '[.[] | select(.type == \"keyboard\")][0] | .identifier') xkb_switch_layout next"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "👁",
            "deactivated": "🔇"
        },
        "start-activated": false,
        "tooltip": true,
        "tooltip-format-activated": "power-saving disabled",
        "tooltip-format-deactivated": "power-saving enabled"
    },
    "custom/dnd": {
        "interval": "once",
        "return-type": "json",
        "format": "{}",
        "on-click": "makoctl mode | grep -qx 'do-not-disturb' && makoctl mode -r do-not-disturb || makoctl mode -a do-not-disturb; pkill -RTMIN+11 waybar",
        "exec": "if makoctl mode | grep -qx 'do-not-disturb'; then printf '{\"text\":\"\ud83d\udd15\",\"tooltip\":\"Do Not Disturb ON\"}'; else printf '{\"text\":\"\ud83d\udd14\",\"tooltip\":\"Notifications on\"}'; fi",
        "signal": 11
    },
    "custom/bluetooth": {
        "format": "",
        "on-click": "blueman-manager",
        "on-click-right": "rfkill toggle bluetooth",
        "tooltip": false
    },
    "custom/power": {
        "format": "⏻",
        "on-click": "~/.local/bin/herdr-powermenu",
        "tooltip": false
    },
    "clock": {
        "format": "🕐 {:%H:%M:%S}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "timezone": "UTC"
    },
    "custom/metrics": {
        "exec": "~/.local/bin/herdr-waybar-metrics",
        "return-type": "json",
        "interval": 3,
        "exec-on-event": false,
        "tooltip": false,
        "format": "{}"
    }
}
